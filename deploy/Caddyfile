# Caddy automatically obtains and renews TLS certificates from Let's Encrypt
# for {$APP_DOMAIN}. HTTPS is mandatory for Web Push, so this is not optional.

{$APP_DOMAIN} {
	encode gzip

	# ---- Caching --------------------------------------------------------------
	#
	# Without these headers a browser heuristically caches index.html, which
	# points at hash-named bundles — so it keeps loading the OLD bundle and the
	# user never sees a new release. The app looks like it did not update, with
	# nothing in the logs to suggest why.
	#
	# Vite fingerprints every file under /assets/, so those are safe to cache
	# forever: a new build produces new filenames.
	@immutable path /assets/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# Everything else must be revalidated on each load. In particular:
	#   index.html            - names the current bundles
	#   /sw.js                - the service worker, which controls updates
	#   /manifest.webmanifest - install metadata
	#   /v1/*                 - API responses, which are never cacheable anyway
	@revalidate not path /assets/*
	header @revalidate Cache-Control "no-cache"

	# ---- Routing --------------------------------------------------------------
	handle /v1/* {
		reverse_proxy server:3000
	}
	handle /a/* {
		reverse_proxy server:3000
	}
	handle /healthz {
		reverse_proxy server:3000
	}

	# The PWA (also served by the Node server, which does SPA fallback to
	# index.html for client-side routes).
	handle {
		reverse_proxy server:3000
	}
}
