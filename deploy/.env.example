# Copy to .env and fill in. setup.sh generates the secret/VAPID values for you.

# ---- Core ----
NODE_ENV=production
PORT=3000
# Public HTTPS URL of the service (must match APP_DOMAIN below).
APP_URL=https://notify.example.com
# Domain Caddy will obtain a TLS certificate for.
APP_DOMAIN=notify.example.com
TENANT_NAME=Home
# Timezone used to evaluate quiet hours. Set this to your actual timezone or
# quiet hours will be off by your UTC offset.
#
# Format: an IANA tz database name, i.e. "Area/Location" (case-sensitive).
#   Valid:   Europe/Helsinki, Europe/Stockholm, America/New_York, Asia/Tokyo, UTC
#   Invalid: EET, GMT+2, +02:00, "Helsinki"
# Abbreviations and UTC offsets are NOT accepted; an offset cannot express
# daylight saving time, so quiet hours would drift by an hour twice a year.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Find yours with: timedatectl show --property=Timezone --value
TZ=Europe/Helsinki

# ---- Datastores (service names resolve inside the compose network) ----
DATABASE_URL=postgres://notify:CHANGE_ME@postgres:5432/notify
REDIS_URL=redis://redis:6379
POSTGRES_PASSWORD=CHANGE_ME

# ---- Web Push (VAPID) — generated by setup.sh ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- SMS (optional). Set to 'none' to disable the SMS channel entirely. ----
# 'mikrotik' | 'twilio' | 'none'
#
# SMS is what makes a critical alert break through a silenced iPhone (via a
# contact with Emergency Bypass). Web push cannot do that, and neither can
# WhatsApp or Signal — they are ordinary app notifications.
SMS_PROVIDER=none

# --- Option A: your own MikroTik router's LTE modem (no monthly fee) ---
# The router MUST be reached over a WireGuard tunnel, never over the internet:
# this URL is its full management API. The server refuses to boot if this is a
# public address. Full setup: docs/MIKROTIK_SMS.md
MIKROTIK_URL=http://10.10.10.2
MIKROTIK_USER=notify-sms
MIKROTIK_PASSWORD=
# Interface carrying the modem, per `/tool sms print` on the router.
MIKROTIK_SMS_PORT=lte1
# Only needed if MIKROTIK_URL uses https with the router's self-signed cert.
MIKROTIK_CA_CERT=

# --- Option B: Twilio (per-message + a recurring monthly fee per number) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- MQTT bridge (optional) ----
MQTT_ENABLED=false
MQTT_URL=mqtt://broker:1883
MQTT_TOPIC_PREFIX=notify/

# ---- Security / behaviour ----
SESSION_SECRET=
# Signs outbound action webhooks (HMAC-SHA256). Optional — falls back to
# SESSION_SECRET — but a dedicated secret is better, because you share this one
# with Home Assistant and should not hand over the key that signs login sessions.
WEBHOOK_SIGNING_SECRET=
# How long a login lasts, in days. 400 is the maximum browsers honour (Chrome
# clamps cookie Max-Age to 400 days). The session *slides*: it is re-issued while
# the app is in use, so an active user is never logged out. Reduce this only if
# you want people re-authenticating on a schedule.
SESSION_MAX_AGE_DAYS=400
ACK_TOKEN_TTL_SECONDS=3600
# Default deduplication window. Can be overridden per topic in Settings.
DEDUP_COOLDOWN_SECONDS=300

# ---- Admin bootstrap (used once by the seed step) ----
ADMIN_NAME=admin
ADMIN_PASSWORD=CHANGE_ME
